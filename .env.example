# === LLM Configuration ===
# GLM (NVIDIA NIM / 智谱)
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4

# Qwen (阿里百炼)
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Default model routing
DEFAULT_INTENT_MODEL=qwen
DEFAULT_PLANNING_MODEL=glm
DEFAULT_CHAT_MODEL=qwen

# === MCP Configuration ===
MCP_ENDPOINT=http://higress-gateway:8080/mcp
MCP_AUTH_TOKEN=your-mcp-token

# === Database ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=travel_agent
POSTGRES_USER=travel
POSTGRES_PASSWORD=travel_secret

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === App ===
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production
BACKEND_PORT=8000
FRONTEND_PORT=3000
